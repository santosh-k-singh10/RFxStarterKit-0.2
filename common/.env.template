# ============================================================================
# RFxStarterKit - MASTER ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env in your module directory and fill in your values
# Different modules may use different subsets of these variables
# ============================================================================

# ----------------------------------------------------------------------------
# LLM PROVIDER CONFIGURATION
# ----------------------------------------------------------------------------
# IBM Services Essentials (OpenAI-compatible API)
OPENAI_API_BASE=https://servicesessentials.ibm.com/apis/v3
OPENAI_API_KEY=your-ibm-services-essentials-api-key
MODEL_ID=global/anthropic.claude-sonnet-4-5-20250929-v1:0

# Alternative: Direct Anthropic API
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Alternative: AWS Bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------------------
# Port for the FastAPI server
PORT=8000

# CORS - Allowed origins (comma-separated or * for all)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# A2A Protocol type: JSONRPC or HTTP+JSON
A2A_PROTOCOL=JSONRPC

# Public URL where this agent is accessible (for agent registration)
PUBLIC_AGENT_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# ICA INTEGRATION (Required for Agent Studio)
# ----------------------------------------------------------------------------
# See: https://github.ibm.com/Consulting-DTT-AI-Integration-Services/agentstudio-external-agent-boilerplate/wiki/How-to-get-required-ICA_*-env-variables

# ICA_API_URL=https://your-ica-instance.com/api
# ICA_CLIENT_ID=your-client-id
# ICA_CLIENT_SECRET=your-client-secret
# ICA_TENANT_ID=your-tenant-id

# ----------------------------------------------------------------------------
# AUTHENTICATION (Optional)
# ----------------------------------------------------------------------------
# Simple bearer token authentication (optional)
# A2A_BEARER_TOKEN=supersecret

# Keycloak JWT validation (optional)
# KEYCLOAK_ISSUER_URL=https://keycloak-host/realms/your-realm
# KEYCLOAK_AUDIENCE=your-client-id
# KEYCLOAK_JWKS_URL=https://keycloak-host/realms/your-realm/protocol/openid-connect/certs
# KEYCLOAK_USERINFO_URL=https://keycloak-host/realms/your-realm/protocol/openid-connect/userinfo

# ----------------------------------------------------------------------------
# IBM ICA MCP GATEWAY CONFIGURATION
# ----------------------------------------------------------------------------
# MCP Gateway Base URL
MCP_BASE_URL=https://your-mcp-gateway-url

# Server ID from IBM ICA Platform
MCP_SERVER_ID=your-server-id

# Access Token (JWT)
MCP_ACCESS_TOKEN=your-mcp-access-token

# Full MCP Server URL (for agents)
MCP_SERVER_URL=https://your-mcp-gateway-url/servers/your-server-id/mcp

# Authorization header (for agents)
MCP_AUTHORIZATION=Bearer your-mcp-access-token

# ----------------------------------------------------------------------------
# CONTEXT STUDIO CONFIGURATION (for RFP Analyzer)
# ----------------------------------------------------------------------------
# Enable Context Studio integration
CONTEXT_STUDIO_ENABLED=false

# Context Studio MCP Gateway URL
CONTEXT_STUDIO_MCP_URL=https://servicesessentials.ibm.com/mcp-gateway/service/gateway/servers/your-server-id/mcp

# Context Studio MCP Token
CONTEXT_STUDIO_MCP_TOKEN=your-context-studio-mcp-token

# Context Studio Context ID
CONTEXT_STUDIO_CONTEXT_ID=your-context-id

# Context Studio Agent Persona
CONTEXT_STUDIO_AGENT_PERSONA=RFPAnalyzer

# Context Studio API Key
CONTEXT_STUDIO_API_KEY=your-context-studio-api-key

# Context Studio Cache Configuration
CONTEXT_STUDIO_CACHE_TTL=300
CONTEXT_STUDIO_CACHE_SIZE=100

# Checkpoint database path (for RFP Analyzer)
CHECKPOINT_DB=./logs/checkpoints.sqlite

# ----------------------------------------------------------------------------
# OBSERVABILITY CONFIGURATION (Arize Phoenix)
# ----------------------------------------------------------------------------
# Enable observability features
OBSERVABILITY_ENABLED=false

# Arize Phoenix endpoint
OBSERVABILITY_PHOENIX_ENDPOINT=https://agentstudio.servicesessentials.ibm.com/api/proxy/observability

# Arize Phoenix API key
OBSERVABILITY_PHOENIX_API_KEY=your-phoenix-api-key

# Project name for Phoenix
OBSERVABILITY_PROJECT_NAME=rfp-analyzer

# Environment name (development, staging, production)
OBSERVABILITY_ENVIRONMENT=production

# Feature flags
OBSERVABILITY_TRACE_AGENTS=true
OBSERVABILITY_TRACE_LLM_CALLS=true
OBSERVABILITY_TRACE_CONTEXT_STUDIO=true
OBSERVABILITY_COLLECT_METRICS=true
OBSERVABILITY_COLLECT_LOGS=true

# Sampling configuration
OBSERVABILITY_TRACE_SAMPLE_RATE=1.0
OBSERVABILITY_METRIC_EXPORT_INTERVAL=60

# Performance tuning
OBSERVABILITY_BATCH_SIZE=100
OBSERVABILITY_EXPORT_TIMEOUT=30
OBSERVABILITY_MAX_QUEUE_SIZE=2048

# ----------------------------------------------------------------------------
# HOOKS CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Enable example hooks for session/tool event monitoring
# AGENTSTUDIO_HOOKS=hooks_example

# ----------------------------------------------------------------------------
# LLM MODEL CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Default model for agents (AWS Bedrock)
# DEFAULT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# DEFAULT_MODEL_REGION=us-east-1

# Model-specific parameters
# MODEL_MAX_TOKENS=4096
# MODEL_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# ----------------------------------------------------------------------------
# DEVELOPMENT/DEBUG (Optional)
# ----------------------------------------------------------------------------
# Enable debug mode
# DEBUG=true

# Disable Python bytecode generation (faster reloads)
# PYTHONDONTWRITEBYTECODE=1