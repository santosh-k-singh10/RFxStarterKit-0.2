# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Logging Configuration
LOG_LEVEL=INFO

# Output Configuration
OUTPUT_DIR=./outputs
CHECKPOINT_DB=./logs/checkpoints.sqlite

# Context Studio MCP Configuration
# Set to 'true' to fetch organizational context from Context Studio via MCP
CONTEXT_STUDIO_ENABLED=false

# Context Studio MCP Server URL (from Bob Configuration)
CONTEXT_STUDIO_MCP_URL=https://servicesessentials.ibm.com/mcp-gateway/service/gateway/servers/8ccdd203bdee4014b08e82eedb6046e2/mcp

# Context Studio Authentication
# MCP Gateway Bearer Token
CONTEXT_STUDIO_MCP_TOKEN=your-mcp-gateway-token-here

# Context Studio API Key
# Context Studio Context ID (your organization's context in Context Studio)
CONTEXT_STUDIO_CONTEXT_ID=your-context-id-here

# Context Studio Agent Persona (optional, default: RFPAnalyzer)
CONTEXT_STUDIO_AGENT_PERSONA=RFPAnalyzer
CONTEXT_STUDIO_API_KEY=your-context-studio-api-key-here

# Context Studio Cache Configuration
CONTEXT_STUDIO_CACHE_TTL=300  # Cache TTL in seconds (default: 5 minutes)
CONTEXT_STUDIO_CACHE_SIZE=100  # Maximum number of cached items

# Optional: Organization ID (if not using default)
# CONTEXT_STUDIO_ORG_ID=your-org-id

# ── Observability Configuration (Arize Phoenix) ──────────────────────────────
# Master switch for all observability features
OBSERVABILITY_ENABLED=true

# Arize Phoenix endpoint URL
OBSERVABILITY_PHOENIX_ENDPOINT=https://agentstudio.servicesessentials.ibm.com/api/proxy/observability

# Arize Phoenix API key for authentication
OBSERVABILITY_PHOENIX_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiJBcGlLZXk6MTUwIn0.pH4vl_x_4dYB63U0HCvq0Igz45xgAYDXLYHhgB-Y14U

# Project name for Phoenix
OBSERVABILITY_PROJECT_NAME=rfp-analyzer

# Environment name (development, staging, production)
OBSERVABILITY_ENVIRONMENT=production

# Feature Flags - Enable/Disable Specific Metrics
OBSERVABILITY_TRACE_AGENTS=true
OBSERVABILITY_TRACE_LLM_CALLS=true
OBSERVABILITY_TRACE_CONTEXT_STUDIO=true
OBSERVABILITY_COLLECT_METRICS=true
OBSERVABILITY_COLLECT_LOGS=true

# Sampling Configuration
OBSERVABILITY_TRACE_SAMPLE_RATE=1.0  # 1.0 = 100% sampling
OBSERVABILITY_METRIC_EXPORT_INTERVAL=60  # seconds

# Performance Tuning
OBSERVABILITY_BATCH_SIZE=100
OBSERVABILITY_EXPORT_TIMEOUT=30  # seconds
OBSERVABILITY_MAX_QUEUE_SIZE=2048
