# ============================================================================
# RFxStarterKit .gitignore
# ============================================================================

# -- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover
.hypothesis/

# -- Virtual environments ----------------------------------------------------
.venv/
venv/
env/
ENV/
.env.backup

# -- Secrets / credentials (never commit) ------------------------------------
.env
.env.*
!.env.template
!common/.env.template

# -- Runtime outputs ---------------------------------------------------------
outputs/
rfp-analyzer/outputs/web/
rfp-analyzer/outputs/*.xlsx
rfp-analyzer/outputs/*.html
rfp-analyzer/outputs/*.json
rfp-analyzer/outputs/*.md
rfp-analyzer/app/outputs/
rfp-analyzer/app/uploads/
rfp-analyzer/uploads/

# -- Logs --------------------------------------------------------------------
*.log
logs/
rfp-analyzer/app/logs/
rfp-analyzer/logs/*.log
!rfp-analyzer/logs/.gitkeep

# -- Databases / checkpoints -------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal

# -- Large binary / data files -----------------------------------------------
*.xlsx
*.xls
!rfp-analyzer/SAP_Analysis_Test.xlsx
*.pdf
!sample-rfps/
*.docx
!sample-rfps/

# -- Temporary files ---------------------------------------------------------
*.tmp
*.temp
temp/
tmp/
~$*.xlsx
~$*.xls
~$*.docx

# -- Debug / working notes (never commit) ------------------------------------
debug_json_error_attempt_1.txt
**/debug_json_error_attempt_*.txt
github-checkin-plan.md

# -- OS / editor -------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# -- Backup files ------------------------------------------------------------
*.backup
*.bak
backup_*/

# -- Node modules (if any) ---------------------------------------------------
node_modules/
package-lock.json
npm-debug.log
yarn-error.log

# -- Docker ------------------------------------------------------------------
.dockerignore
docker-compose.override.yml


# -- Testing artifacts -------------------------------------------------------
.tox/
.nox/
.coverage.*
nosetests.xml
test-results/
*.cover

# -- Documentation builds ----------------------------------------------------
docs/_build/
site/

# -- IDE specific ------------------------------------------------------------
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -- Jupyter Notebooks -------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -- Keep empty directories --------------------------------------------------
!.gitkeep

# ============================================================================